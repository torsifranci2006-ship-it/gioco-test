{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "scene.schema.json",
  "title": "Scena narrativa",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": { "^_": {} },
  "required": ["id", "titolo", "testo"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "titolo": { "type": "string" },
    "atto": { "type": "string" },
    "precondizioni": {
      "description": "Condizione di ingresso scena. Null = sempre accessibile.",
      "oneOf": [{ "$ref": "condition.schema.json" }, { "type": "null" }]
    },
    "testo": {
      "description": "Frammenti mostrati in ordine; ciascuno appare solo se la sua condizione è vera (null = sempre).",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contenuto"],
        "properties": {
          "contenuto": { "type": "string" },
          "personaggio": { "type": "string", "description": "id del parlante, opzionale" },
          "condizione": { "oneOf": [{ "$ref": "condition.schema.json" }, { "type": "null" }] }
        }
      }
    },
    "on_enter": {
      "description": "Effetti applicati all'ingresso della scena.",
      "oneOf": [{ "$ref": "effect.schema.json" }, { "type": "null" }]
    },
    "scelte": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "testo", "prossima"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "testo": { "type": "string" },
          "visibile_se": {
            "description": "Se falsa, la scelta è nascosta.",
            "oneOf": [{ "$ref": "condition.schema.json" }, { "type": "null" }]
          },
          "abilitata_se": {
            "description": "Se falsa, la scelta è mostrata disabilitata con motivo_blocco.",
            "oneOf": [{ "$ref": "condition.schema.json" }, { "type": "null" }]
          },
          "motivo_blocco": { "type": ["string", "null"] },
          "effetti": { "oneOf": [{ "$ref": "effect.schema.json" }, { "type": "null" }] },
          "prossima": {
            "description": "id della scena successiva, oppure 'finale' per innescare la risoluzione del finale.",
            "type": "string"
          }
        }
      }
    },
    "prossima_default": {
      "description": "Per scene senza scelte: scena successiva automatica.",
      "type": ["string", "null"]
    },
    "visual": {
      "description": "Metadati di presentazione per la UI (opzionale). Assente/null = fallback UI.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background": { "type": ["string", "null"] },
        "portrait": { "type": ["string", "null"] }
      }
    }
  }
}
