{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attributes.schema.json",
  "title": "Configurazione attributi nascosti",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": { "^_": {} },
  "required": ["attributi"],
  "properties": {
    "attributi": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "nome", "min", "max", "default"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "nome": { "type": "string" },
          "descrizione": { "type": "string" },
          "min": { "type": "integer" },
          "max": { "type": "integer" },
          "default": { "type": "integer" },
          "nascosto": { "type": "boolean", "default": true }
        }
      }
    }
  }
}
